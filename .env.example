# Path to the existing SQLite database from the Python data-sync service
DATABASE_PATH=../../Adobe-Templatization/data-sync/data/database.sqlite

# Directory where attachment_sync downloads asset files
ASSET_DIR=../../Adobe-Templatization/data-sync/data/assets

# Authentication
JWT_SECRET=change-me-to-a-random-256-bit-key
SHARED_SECRET=change-me
ALLOWED_USERS=designer@company.com,admin@company.com

# Server
PORT=3200
HOST=127.0.0.1

# Audit database (separate from brand data)
AUDIT_DB_PATH=./data/audit.sqlite
