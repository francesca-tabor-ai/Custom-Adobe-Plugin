{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@brand-sync/shared": ["../../shared/src"],
      "@brand-sync/plugin-core": ["../../plugin-core/src"]
    }
  },
  "include": ["src/**/*"]
}
