{
  "id": "com.enterprise.brand-sync",
  "name": "Brand Sync & Governance",
  "version": "1.0.0",
  "manifestVersion": 5,
  "main": "index.js",
  "host": [
    {
      "app": "InDesign",
      "minVersion": "18.0"
    },
    {
      "app": "Photoshop",
      "minVersion": "24.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "brandSyncPanel",
      "label": {
        "default": "Brand Sync"
      },
      "minimumSize": {
        "width": 280,
        "height": 400
      },
      "maximumSize": {
        "width": 500,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 320,
        "height": 600
      }
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": [
        "localhost",
        "127.0.0.1"
      ]
    },
    "localFileSystem": "fullAccess",
    "clipboard": "readAndWrite"
  },
  "icons": []
}
